# Optional: override the JWT signing secret used by authentication.
JWT_SECRET="replace-with-a-long-random-secret"

# Optional: override the port used by the local server.
PORT="3000"

# Optional: point the app at your MongoDB instance.
MONGODB_URI="mongodb://127.0.0.1:27017/northstar-notes"

# Optional: set this when the frontend should call a separate backend host.
# Example for Render: https://your-app-name.onrender.com
VITE_API_URL=""

